# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Contact Information (Required by Nominatim)
CONTACT_EMAIL=your-email@example.com

# API Keys (Required for external services)
EVENTBRITE_TOKEN=your_eventbrite_token_here
NEWSAPI_KEY=your_newsapi_key_here

# Database Configuration
DATABASE_URL=sqlite:///./data/dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/hybrid_ai_location

# Redis Configuration
REDIS_URL=redis://localhost:6379

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI/LLM Configuration (Optional)
LLM_PROVIDER=none  # Options: openai, anthropic, none
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Development Settings
DEBUG=true
LOG_LEVEL=INFO

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# External API Timeouts (seconds)
NOMINATIM_TIMEOUT=10
POLICE_API_TIMEOUT=15
EVENTBRITE_TIMEOUT=15
NEWSAPI_TIMEOUT=15
OVERPASS_TIMEOUT=20

# Cache TTL (seconds)
GEOCODE_CACHE_TTL=604800  # 7 days
CRIME_CACHE_TTL=3600      # 1 hour
EVENT_CACHE_TTL=1800      # 30 minutes
NEWS_CACHE_TTL=900        # 15 minutes
POI_CACHE_TTL=86400       # 1 day






