# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Contact Information (Required by Nominatim)
CONTACT_EMAIL=your-email@example.com

# API Keys (Required for external services)
EVENTBRITE_TOKEN=your_eventbrite_token_here
NEWSAPI_KEY=your_newsapi_key_here

# Database Configuration
DATABASE_URL=sqlite:///./data/dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/hybrid_ai_location

# Redis Configuration
REDIS_URL=redis://localhost:6379

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI/LLM Configuration (Optional)
LLM_PROVIDER=none  # Options: openai, anthropic, none
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Development Settings
DEBUG=true
LOG_LEVEL=INFO

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# External API Timeouts (seconds)
NOMINATIM_TIMEOUT=10
POLICE_API_TIMEOUT=15
EVENTBRITE_TIMEOUT=15
NEWSAPI_TIMEOUT=15
OVERPASS_TIMEOUT=20

# Cache TTL (seconds)
GEOCODE_CACHE_TTL=604800  # 7 days
CRIME_CACHE_TTL=3600      # 1 hour
EVENT_CACHE_TTL=1800      # 30 minutes
NEWS_CACHE_TTL=900        # 15 minutes
POI_CACHE_TTL=86400       # 1 day

# Real-time Data Filtering (for location data panel)
# These settings control how recent the data shown in the location panel is

# Crimes: UK Police API provides monthly aggregated data
# For "near real-time": use 1-7 days (shows only most recent crimes)
# For historical: use 30 days (shows all available crimes)
CRIME_RECENT_DAYS=7  # Show crimes from last N days (1-30 recommended)

# News: NewsAPI can provide very recent articles
# For "near real-time": use 1-24 hours (shows only latest news)
# For broader coverage: use 48-168 hours (1-7 days)
NEWS_RECENT_HOURS=24  # Show news from last N hours (1-168 recommended)

# Events: Show upcoming events and recent past
EVENT_RECENT_HOURS=24  # Show events from last N hours
EVENT_FUTURE_HOURS=168  # Show events in next N hours (168 = 7 days)






